# ============================================
# EduFlow CRM Backend — Environment Variables
# Step 13: Production Ready
# ============================================
# Copy this file to .env and fill in values
# cp .env.example .env
# ============================================

# ─── SERVER ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api

# Node process timezone — required so cron.service.ts's birthday/payment-due
# date matching is correct regardless of the host/container's default TZ.
TZ=Asia/Tashkent

# ─── DATABASE (Neon PostgreSQL) ───────────────────────────────────────────────
# DATABASE_URL : Pooled connection string (for app queries via PgBouncer)
# DIRECT_URL   : Direct connection string (for Prisma migrations, bypasses pooler)
# Get both from: Neon Dashboard → Your Project → Connection Details
DATABASE_URL=postgresql://user:password@host-pooler/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── JWT SECRETS ─────────────────────────────────────────────────────────────
# Generate strong secrets (minimum 32 chars / recommended 64):
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Run twice — one for JWT_SECRET, one for JWT_REFRESH_SECRET
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-here
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Development : http://localhost:5173
# Production  : https://your-app.vercel.app
# Multiple    : https://your-app.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ─── SECURITY ─────────────────────────────────────────────────────────────────
# Bcrypt rounds: 10 = dev, 12 = production (higher = slower but more secure)
BCRYPT_ROUNDS=10

# ─── RATE LIMITING ────────────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW_MS: Time window in ms (900000 = 15 minutes)
# RATE_LIMIT_MAX_REQUESTS: Max requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# ─── TELEGRAM BOT (Optional — for notifications) ─────────────────────────────
# Get token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── PRODUCTION CHECKLIST ─────────────────────────────────────────────────────
# Before deploying to production:
# [x] Set NODE_ENV=production
# [x] Use strong JWT secrets (64 chars hex)
# [x] Set BCRYPT_ROUNDS=12
# [x] Set correct CORS_ORIGIN (your Vercel URL)
# [x] Use Neon pooled URL for DATABASE_URL
# [x] Use Neon direct URL for DIRECT_URL
# [x] Run: npx prisma migrate deploy
# [x] Run: node seed-plans.js
# [x] Run: node create-superadmin.js
